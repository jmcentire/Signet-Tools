  <section class="py-28 bg-background">
    <div class="max-w-6xl mx-auto px-6">
      <span class="font-mono text-xs text-gold uppercase tracking-widest">Ephemeral Messaging</span>
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight mt-3 mb-4 max-w-2xl">
        Messages that exist only in transit.
      </h2>
      <p class="text-secondary max-w-2xl mb-8 leading-relaxed">
        Decentralized peer-to-peer messaging. No servers, no persistence, no metadata. Ed25519 signing with NaCl encryption. When the recipient reads it, it's gone.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="https://hp2p.net" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-gold hover:text-gold-bright transition-colors flex items-center gap-1.5">
          hp2p.net
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
